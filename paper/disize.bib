@article{hong_rna_2020,
	title = {{RNA} sequencing: new technologies and applications in cancer research},
	volume = {13},
	issn = {1756-8722},
	shorttitle = {{RNA} sequencing},
	doi = {10.1186/s13045-020-01005-x},
	abstract = {Over the past few decades, RNA sequencing has significantly progressed, becoming a paramount approach for transcriptome profiling. The revolution from bulk RNA sequencing to single-molecular, single-cell and spatial transcriptome approaches has enabled increasingly accurate, individual cell resolution incorporated with spatial information. Cancer, a major malignant and heterogeneous lethal disease, remains an enormous challenge in medical research and clinical treatment. As a vital tool, RNA sequencing has been utilized in many aspects of cancer research and therapy, including biomarker discovery and characterization of cancer heterogeneity and evolution, drug resistance, cancer immune microenvironment and immunotherapy, cancer neoantigens and so on. In this review, the latest studies on RNA sequencing technology and their applications in cancer are summarized, and future challenges and opportunities for RNA sequencing technology in cancer applications are discussed.},
	number = {1},
	urldate = {2025-08-27},
	journal = {Journal of Hematology \& Oncology},
	author = {Hong, Mingye and Tao, Shuang and Zhang, Ling and Diao, Li-Ting and Huang, Xuanmei and Huang, Shaohui and Xie, Shu-Juan and Xiao, Zhen-Dong and Zhang, Hua},
	month = dec,
	year = {2020},
	keywords = {RNA sequencing, Application, Cancer},
	pages = {166},
	file = {Full Text PDF:/Users/todd/Zotero/storage/NSXIG4JR/Hong et al. - 2020 - RNA sequencing new technologies and applications in cancer research.pdf:application/pdf;Snapshot:/Users/todd/Zotero/storage/SEM7TNGM/s13045-020-01005-x.html:text/html},
}

@article{anders_differential_2010,
	title = {Differential expression analysis for sequence count data},
	volume = {11},
	issn = {1474-760X},
	doi = {10.1186/gb-2010-11-10-r106},
	abstract = {High-throughput sequencing assays such as RNA-Seq, ChIP-Seq or barcode counting provide quantitative readouts in the form of count data. To infer differential signal in such data correctly and with good statistical power, estimation of data variability throughout the dynamic range and a suitable error model are required. We propose a method based on the negative binomial distribution, with variance and mean linked by local regression and present an implementation, DESeq, as an R/Bioconductor package.},
	number = {10},
	urldate = {2025-08-27},
	journal = {Genome Biology},
	author = {Anders, Simon and Huber, Wolfgang},
	month = oct,
	year = {2010},
	keywords = {Local Regression, Negative Binomial, Negative Binomial Distribution, Shot Noise, Size Factor},
	pages = {R106},
	file = {Full Text PDF:/Users/todd/Zotero/storage/LVXXV8YF/Anders and Huber - 2010 - Differential expression analysis for sequence count data.pdf:application/pdf},
}

@article{love_moderated_2014,
	title = {Moderated estimation of fold change and dispersion for {RNA}-seq data with {DESeq2}},
	volume = {15},
	issn = {1474-760X},
	doi = {10.1186/s13059-014-0550-8},
	abstract = {In comparative high-throughput sequencing assays, a fundamental task is the analysis of count data, such as read counts per gene in RNA-seq, for evidence of systematic changes across experimental conditions. Small replicate numbers, discreteness, large dynamic range and the presence of outliers require a suitable statistical approach. We present DESeq2, a method for differential analysis of count data, using shrinkage estimation for dispersions and fold changes to improve stability and interpretability of estimates. This enables a more quantitative analysis focused on the strength rather than the mere presence of differential expression. The DESeq2 package is available at http://www.bioconductor.org/packages/release/bioc/html/DESeq2.html.},
	number = {12},
	urldate = {2025-08-27},
	journal = {Genome Biology},
	author = {Love, Michael I. and Huber, Wolfgang and Anders, Simon},
	month = dec,
	year = {2014},
	keywords = {DESeq2 Package, Differential Expression Analysis, Negative Binomial Generalize Linear Model, Observe Fisher Information, Read Count},
	pages = {550},
	file = {Full Text PDF:/Users/todd/Zotero/storage/8MHEMJEJ/Love et al. - 2014 - Moderated estimation of fold change and dispersion for RNA-seq data with DESeq2.pdf:application/pdf},
}

